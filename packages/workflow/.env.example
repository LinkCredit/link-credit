# — Plaid (sandbox) —
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret

# — OpenAI (for AI scoring) —
OPENAI_API_KEY=sk-your_openai_api_key

# — Encryption (32-byte hex key for AES-GCM token encryption) —
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# — Worker authentication (shared secret) —
WORKER_API_KEY=dev-api-key-change-me

# — Worker endpoint (where this workflow calls back) —
WORKER_BASE_URL=http://localhost:3001

CRE_ETH_PRIVATE_KEY=
