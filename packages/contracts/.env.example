# Sepolia RPC (required, used by foundry.toml [rpc_endpoints])
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Deployer address (read by script via vm.envOr, falls back to msg.sender)
DEPLOYER_ADDRESS=0x_YOUR_DEPLOYER_ADDRESS

# Etherscan verification (optional, for --verify flag)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
