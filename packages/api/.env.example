# Plaid
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_BASE_URL=https://sandbox.plaid.com
# Optional: OAuth redirect URI (defaults to http://localhost:5173 if not set)
PLAID_REDIRECT_URI=http://localhost:5173

# Chainlink Runtime Environment (CRE)
CRE_GATEWAY_URL=https://gateway.chain.link/v1/workflows/execute
CRE_WORKFLOW_METHOD=workflow_execute
CRE_WORKFLOW_ID=your_cre_workflow_id
CRE_WORLDID_WORKFLOW_ID=your_worldid_workflow_id
CRE_WORKER_PRIVATE_KEY=0xyour_cre_worker_private_key

# World ID v4 Configuration
WORLDCOIN_APP_ID=app_staging_xxx
WORLDCOIN_RP_ID=rp_xxx
WORLDCOIN_RP_SIGNING_KEY=0xyour_rp_signing_key

# Internal API auth
WORKER_API_KEY=your_worker_api_key

# Cloudflare KV
# ACCESS_TOKEN_KV is configured as a Worker binding in production.
# Local fallback is only enabled when NODE_ENV=development/test
# or ALLOW_IN_MEMORY_KV_FALLBACK=true.
ALLOW_IN_MEMORY_KV_FALLBACK=true
