# — Frontend Configuration (optional — sensible defaults for local dev) —

# API server URL (local dev or deployed)
# VITE_API_BASE_URL=http://localhost:3001

# WalletConnect project ID (for wallet connection)
# Get it from: https://cloud.walletconnect.com
# VITE_WALLETCONNECT_PROJECT_ID=

# World ID app id (Developer Portal)
# VITE_WORLDCOIN_APP_ID=app_staging_xxx

# Tenderly Sepolia Fork (optional)
# Create a fork from Sepolia in Tenderly Dashboard, then paste the RPC URL:
# VITE_TENDERLY_FORK_RPC_URL=https://rpc.tenderly.co/fork/YOUR_FORK_ID
