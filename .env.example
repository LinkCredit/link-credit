# Copy to project root as .env and fill from Plaid Dashboard
# https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret

# Optional: if llm.selected_provider=openai
OPENAI_API_KEY=your_openai_api_key

# Optional: if llm.selected_provider=deepseek
PPIO_API_KEY=your_ppinfra_api_key
