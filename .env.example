# --- Plaid / AI ---
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
OPENAI_API_KEY=your_openai_api_key

# Optional: if llm.selected_provider=deepseek
PPIO_API_KEY=your_ppinfra_api_key

# --- CRE Workflow + API ---
